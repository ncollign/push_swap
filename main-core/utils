#include "main-core/push_swap.h"

t_stack	*last_element(t_stack *stack)
{
	if (stack == NULL)
		return NULL;

	while (stack->next != NULL)
	{
		stack = stack->next;
	}
	return stack;
}

int ft_strisnumber(const char *str)
{
	if (!str || *str == '\0')
		return 0;
	while (*str == ' ')
		str++;
	if (*str == '-' || *str == '+')
		str++;
	while (*str)
	{
		if (!ft_isdigit((int)*str))
			return (EXIT_FAILURE);
		str++;
	}
	return (EXIT_SUCCESS);
}
